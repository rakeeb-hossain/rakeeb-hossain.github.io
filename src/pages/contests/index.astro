---
import Layout from "../../layouts/Layout.astro";
---

<Layout title={"Contests"}>
  <div class="not-prose">
    <h1 class="text-3xl font-bold tracking-tight mb-1">Contests</h1>
    <p id="contests-meta" class="text-sm text-gray-600 mb-8">
      Upcoming and recent rounds on Codeforces and AtCoder.
    </p>

    <div id="next-contest" class="mb-10"></div>

    <div id="contests-root" class="grid gap-12 md:grid-cols-2">
      <p id="contests-status" class="text-gray-500 md:col-span-2">
        Loading contests…
      </p>
    </div>
  </div>
</Layout>

<script>
  import type { Contest, ContestsPayload, Judge } from "../../lib/contests";

  const JUDGES: ReadonlyArray<{ id: Judge; label: string }> = [
    { id: "codeforces", label: "Codeforces" },
    { id: "atcoder", label: "AtCoder" },
  ];

  const MAX_UPCOMING = 3;
  const MAX_RECENT = 3;

  const absoluteFmt = new Intl.DateTimeFormat(undefined, {
    month: "short",
    day: "numeric",
    hour: "numeric",
    minute: "2-digit",
  });
  const relativeFmt = new Intl.RelativeTimeFormat(undefined, {
    numeric: "auto",
  });

  const MINUTE = 60_000;
  const HOUR = 60 * MINUTE;
  const DAY = 24 * HOUR;
  const WEEK = 7 * DAY;

  function el<K extends keyof HTMLElementTagNameMap>(
    tag: K,
    className?: string,
    text?: string,
  ): HTMLElementTagNameMap[K] {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text !== undefined) node.textContent = text;
    return node;
  }

  function formatRelative(targetMs: number, now: number): string {
    const diff = targetMs - now;
    const abs = Math.abs(diff);
    if (abs < HOUR)
      return relativeFmt.format(Math.round(diff / MINUTE), "minute");
    if (abs < DAY) return relativeFmt.format(Math.round(diff / HOUR), "hour");
    if (abs < WEEK) return relativeFmt.format(Math.round(diff / DAY), "day");
    return relativeFmt.format(Math.round(diff / WEEK), "week");
  }

  function contestEndMs(contest: Contest): number {
    return contest.startMs + (contest.durationSeconds ?? 0) * 1000;
  }

  function renderContestRow(contest: Contest, now: number): HTMLElement {
    const isLive = contest.startMs <= now && now < contestEndMs(contest);

    const row = el("a", "group block py-1.5");
    row.href = contest.url;
    row.target = "_blank";
    row.rel = "noopener noreferrer";

    row.appendChild(
      el(
        "div",
        "text-black group-hover:underline underline-offset-2",
        contest.name,
      ),
    );

    const meta = el("div", "mt-0.5 text-sm text-gray-500");
    if (isLive) {
      meta.appendChild(
        el("span", "mr-1.5 font-medium text-red-600", "● Live"),
      );
    }
    meta.appendChild(
      document.createTextNode(
        `${formatRelative(contest.startMs, now)} · ${absoluteFmt.format(
          contest.startMs,
        )}`,
      ),
    );
    row.appendChild(meta);

    return row;
  }

  function renderList(
    title: string,
    contests: Contest[],
    now: number,
    emptyText: string,
  ): HTMLElement {
    const section = el("div");
    section.appendChild(
      el(
        "h3",
        "mb-2 text-xs font-medium uppercase tracking-wider text-gray-400",
        title,
      ),
    );

    if (contests.length === 0) {
      section.appendChild(el("p", "text-sm text-gray-400", emptyText));
      return section;
    }

    const list = el("div", "space-y-1");
    for (const contest of contests) {
      list.appendChild(renderContestRow(contest, now));
    }
    section.appendChild(list);
    return section;
  }

  function renderJudge(
    config: { id: Judge; label: string },
    contests: Contest[],
    error: string | undefined,
    now: number,
  ): HTMLElement {
    const section = el("section");
    section.appendChild(el("h2", "mb-4 text-lg font-semibold", config.label));

    if (error) {
      section.appendChild(
        el("p", "text-sm text-gray-400", `Couldn't load ${config.label}.`),
      );
      return section;
    }

    const upcoming = contests
      .filter((c) => now < contestEndMs(c))
      .sort((a, b) => a.startMs - b.startMs)
      .slice(0, MAX_UPCOMING);
    const recent = contests
      .filter((c) => now >= contestEndMs(c))
      .sort((a, b) => b.startMs - a.startMs)
      .slice(0, MAX_RECENT);

    const groups = el("div", "space-y-6");
    groups.appendChild(
      renderList("Upcoming", upcoming, now, "No upcoming contests."),
    );
    groups.appendChild(
      renderList("Recent", recent, now, "No recent contests."),
    );
    section.appendChild(groups);

    return section;
  }

  function setMeta(): void {
    const meta = document.getElementById("contests-meta");
    if (!meta) return;
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    meta.textContent = `Times shown in ${tz}.`;
  }

  function judgeName(judge: Judge): string {
    return JUDGES.find((j) => j.id === judge)?.label ?? judge;
  }

  function renderNextContest(payload: ContestsPayload, now: number): void {
    const host = document.getElementById("next-contest");
    if (!host) return;
    host.replaceChildren();

    const next = [...payload.codeforces, ...payload.atcoder]
      .filter((c) => c.startMs > now)
      .sort((a, b) => a.startMs - b.startMs)[0];
    if (!next) return;

    const card = el(
      "a",
      "group block rounded-lg border border-gray-200 p-4 transition hover:border-gray-400",
    );
    card.href = next.url;
    card.target = "_blank";
    card.rel = "noopener noreferrer";

    card.appendChild(
      el(
        "div",
        "text-xs font-medium uppercase tracking-wider text-gray-400",
        "Next contest",
      ),
    );
    card.appendChild(
      el(
        "div",
        "mt-1 font-medium text-black group-hover:underline underline-offset-2",
        next.name,
      ),
    );
    card.appendChild(
      el(
        "div",
        "mt-0.5 text-sm text-gray-500",
        `${judgeName(next.judge)} · ${formatRelative(next.startMs, now)} · ${absoluteFmt.format(next.startMs)}`,
      ),
    );

    host.appendChild(card);
  }

  function render(payload: ContestsPayload): void {
    const root = document.getElementById("contests-root");
    if (!root) return;
    const now = Date.now();

    root.replaceChildren();
    for (const config of JUDGES) {
      const contests =
        config.id === "codeforces" ? payload.codeforces : payload.atcoder;
      root.appendChild(
        renderJudge(config, contests, payload.errors[config.id], now),
      );
    }
    setMeta();
  }

  function showError(): void {
    const status = document.getElementById("contests-status");
    if (status) {
      status.textContent =
        "Couldn't load contests right now. Please try again later.";
    }
  }

  async function load(): Promise<void> {
    try {
      const response = await fetch("/api/contests");
      if (!response.ok) throw new Error(`Request failed: ${response.status}`);
      const payload = (await response.json()) as ContestsPayload;
      render(payload);
    } catch {
      showError();
    }
  }

  void load();
</script>
