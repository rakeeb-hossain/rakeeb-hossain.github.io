---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export function titleToSlug(title: string) {
  return title
    .toLowerCase()
    .replace(/ /g, "-")
    .replace(/[^a-z0-9-]/g, "");
}

// Get all articles from the collection
const articles = (await getCollection("articles")).filter(
  (article) => !article.data.draft,
);

// Sort articles by date (newest first)
const sortedArticles = articles.sort(
  (a: CollectionEntry<"articles">, b: CollectionEntry<"articles">) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout title={"Articles"}>
  <div class="not-prose">
    <h1 class="text-2xl font-semibold tracking-[-0.01em] mb-8">Articles</h1>

    <div class="space-y-4.5">
      {
        sortedArticles.map((article) => (
          <div class="flex gap-4.5 items-baseline">
            <span class="font-mono text-[12.5px] text-muted whitespace-nowrap">
              {new Date(article.data.date).toISOString().slice(0, 10)}
            </span>
            <a
              href={`/articles/${titleToSlug(article.data.title)}`}
              class="text-[1.05rem] hover:text-accent transition"
            >
              {article.data.title}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
