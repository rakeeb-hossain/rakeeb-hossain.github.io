---
import "../styles/global.css";
import Prose from "../components/Prose.astro";

const { title: explicitTitle } = Astro.props as { title?: string };
const { frontmatter } = Astro.props as { frontmatter?: { title?: string } };
const title = explicitTitle ?? frontmatter?.title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} | Append-Only` : "Append-Only"}</title>
  </head>
  <body class="bg-paper text-ink flex flex-col min-h-screen">
    <header class="container mx-auto max-w-180 px-7 pt-16 pb-12">
      <div class="flex justify-between items-baseline">
        <a href="/" class="font-mono text-[1.05rem]"
          >Append-Only<span class="cursor">_</span></a
        >
        <nav class="font-mono text-[12.5px] text-muted space-x-4">
          <a href="/articles" class="hover:text-ink transition"> Articles </a>
          <a href="/contests" class="hover:text-ink transition"> Contests </a>
          <a href="/about" class="hover:text-ink transition"> About </a>
        </nav>
      </div>
    </header>

    <main class="container mx-auto max-w-180 px-7 grow">
      <Prose>
        <slot />
      </Prose>
    </main>

    <footer
      class="container mx-auto max-w-180 px-7 py-10 mt-16 font-mono text-[12px] text-muted"
    >
      &copy; {new Date().getFullYear()} Rakeeb Hossain
    </footer>
  </body>
</html>

<style>
  .cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    from,
    to {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
