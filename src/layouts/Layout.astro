---
import "../styles/global.css";
import Prose from "../components/Prose.astro";

const { title: explicitTitle } = Astro.props as { title?: string };
const { frontmatter } = Astro.props as { frontmatter?: { title?: string } };
const title = explicitTitle ?? frontmatter?.title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} | Rakeeb Hossain` : "Rakeeb Hossain"}</title>
  </head>
  <body class="bg-paper text-ink flex flex-col min-h-screen">
    <header class="container mx-auto max-w-165 px-7 pt-16 pb-12">
      <div class="flex justify-between items-baseline">
        <div>
          <a
            href="/"
            class="font-mono text-[1.4rem] font-semibold tracking-tight"
          >
            Rakeeb Hossain
          </a>
          <div class="font-mono text-[12px] text-muted mt-1.5">
            New York <span class="text-muted/50">·</span> Toronto
          </div>
        </div>
        <nav class="font-mono text-[1.05rem] font-medium space-x-4">
          <a
            href="/articles"
            class="text-accent underline underline-offset-4 decoration-1 hover:opacity-70 transition"
          >
            Writing
          </a>
        </nav>
      </div>
    </header>

    <main class="container mx-auto max-w-165 px-7 grow">
      <Prose>
        <slot />
      </Prose>
    </main>

    <footer
      class="container mx-auto max-w-165 px-7 py-10 mt-16 font-mono text-[12px] text-muted"
    >
      &copy; {new Date().getFullYear()} Rakeeb Hossain
    </footer>
  </body>
</html>
